    "@mui/material": "^5.15.0",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.0",
    "react-router-dom": "^6.20.0",
    "yup": "^1.3.3"
